{
  "buildCommand": "pnpm build:examples && cd website && pnpm prepare-examples && pnpm build",
  "outputDirectory": "website/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/examples/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
